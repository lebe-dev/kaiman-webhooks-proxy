---
import Layout from "../layouts/Layout.astro";
import App from "../components/App.svelte";
import "../styles/global.css";
import { ModeWatcher } from "mode-watcher";
---

<script is:inline>
    const isBrowser = typeof localStorage !== "undefined";

    if (isBrowser) {
        // Set mode-watcher defaults to light theme if not already set
        if (!localStorage.getItem("mode-watcher-mode")) {
            localStorage.setItem("mode-watcher-mode", "light");
        }
        if (!localStorage.getItem("mode-watcher-theme")) {
            localStorage.setItem("mode-watcher-theme", "light");
        }
    }

    const getThemePreference = () => {
        if (isBrowser && localStorage.getItem("theme")) {
            return localStorage.getItem("theme");
        }
        return "light";
    };
    const isDark = getThemePreference() === "dark";
    document.documentElement.classList[isDark ? "add" : "remove"]("dark");

    if (isBrowser) {
        const observer = new MutationObserver(() => {
            const isDark = document.documentElement.classList.contains("dark");
            localStorage.setItem("theme", isDark ? "dark" : "light");
        });
        observer.observe(document.documentElement, {
            attributes: true,
            attributeFilter: ["class"],
        });
    }
</script>

<Layout>
    <ModeWatcher client:load />
    <App client:only="svelte" />
</Layout>

channels:
  # Telegram channel example (plain secret — default)
  - name: telegram
    # Token used for READING webhooks from this proxy (Bearer auth)
    api-read-token: "your_read_token_here"
    # Secret used to VERIFY incoming webhooks from Telegram (plain comparison)
    webhook-secret: "your_webhook_secret_here"
    # Header where Telegram sends the webhook-secret
    secret-header: "X-Telegram-Bot-Api-Secret-Token"
    # max-body-size: 524288  # Optional: override DEFAULT_BODY_LIMIT for this channel (bytes)
    # allowed-ips:            # Optional: restrict source IPs (supports CIDR notation)
    #   - "149.154.160.0/20"  # Telegram webhook servers
    #   - "91.108.4.0/22"
    # forward:                       # Optional: auto-forward webhooks to a target URL
    #   url: "https://my-app.local/telegram-hook"
    #   interval-seconds: 30         # How often to check for pending webhooks
    #   expected-status: 200         # Default: 200. Delete webhook only on this status
    #   timeout-seconds: 15          # Default: 15. HTTP request timeout

  # GitHub channel example (HMAC-SHA256)
  - name: github
    # Token used for READING webhooks from this proxy
    api-read-token: "your_github_read_token_here"
    # Shared secret configured in GitHub webhook settings
    webhook-secret: "your_github_secret_here"
    # Header where GitHub sends the HMAC signature
    secret-header: "X-Hub-Signature-256"
    # Use HMAC-SHA256 verification instead of plain comparison
    secret-type: hmac-sha256
    # Strip the "sha256=" prefix from the header value before comparing
    secret-extract-template: '{{ raw | replace(from="sha256=", to="") }}'
    forward:
      url: "https://my-app.local/github-hook"
      interval-seconds: 30
      # Optional: sign forwarded requests with HMAC
      sign-header: "X-Hub-Signature-256"
      sign-secret: "forward_secret"
      sign-template: "sha256={{ signature }}"

  # Open channel example (no verification)
  - name: open
    # Token used for READING webhooks from this proxy
    api-read-token: "your_open_read_token_here"
    # No webhook-secret means this channel accepts any incoming POST request without verification
